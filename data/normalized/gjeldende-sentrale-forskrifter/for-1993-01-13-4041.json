  "sections": [
    {
      "section_id": "paragraf-1",
      "provision_ref": "§ 1",
      "path": [],
      "text": "Fristen for å kreve lovlighetskontroll for medlemmer av kommunestyret eller fylkestinget er 3 uker.",
      "xml_path": "article#paragraf-1"
    },
    {
      "section_id": "paragraf-2",
      "provision_ref": "§ 2",
      "path": [],
      "text": "Fristen løper fra det tidspunkt avgjørelsen ble truffet.\nFor beregning av fristen gjelder forvaltningsloven § 30 tilsvarende.",
      "xml_path": "article#paragraf-2"
    },
    {
      "section_id": "paragraf-3",
      "provision_ref": "§ 3",
      "path": [],
      "text": "Denne forskrift trer i kraft straks.",
      "xml_path": "article#paragraf-3"
    }
  ]
}
