  "raw_xml_sha256": "bba095d6b29b027652a5af4ef25794775b3dc55be77421c2bda977c413f1be0f",
  "sections": [
    {
      "section_id": "paragraf-1",
      "provision_ref": "§ 1",
      "path": [],
      "text": "Døgnet i § 8 fjerde ledd i i lov 15. august 2014 nr. 61 om losordningen regnes fra det tidspunkt losen etter tilsigelse møter frem for å overta losingen.",
      "xml_path": "article#paragraf-1"
    },
    {
      "section_id": "paragraf-2",
      "provision_ref": "§ 2",
      "path": [],
      "text": "Utfører en los flere losinger i et døgn, har han krav på til sammen tolv timers tjenestefrihet fra losing i døgnet.",
      "xml_path": "article#paragraf-2"
    },
    {
      "section_id": "paragraf-3",
      "provision_ref": "§ 3",
      "path": [],
      "text": "Tjenestefriheten må ikke deles i mer enn 2 perioder.",
      "xml_path": "article#paragraf-3"
    },
    {
      "section_id": "paragraf-4",
      "provision_ref": "§ 4",
      "path": [],
      "text": "Tidspunktet for tjenestefriheten fastsettes i alle tilfeller etter avtale med skipets fører.",
      "xml_path": "article#paragraf-4"
    },
    {
      "section_id": "paragraf-5",
      "provision_ref": "§ 5",
      "path": [],
      "text": "Forskriften trer i kraft 1. januar 1992.",
      "xml_path": "article#paragraf-5"
    }
  ]
}
