  "title": "Forskrift om losers tjenestefrihet av sikkerhetshensyn",
  "short_title": "Forskrift om losers tjenestefrihet",
  "department": "Nærings- og fiskeridepartementet",
  "date_in_force": "1992-01-01",
  "last_change_in_force": "2015-01-01",
