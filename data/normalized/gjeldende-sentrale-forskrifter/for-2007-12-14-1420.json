  "sections": [
    {
      "section_id": "paragraf-1",
      "provision_ref": "§ 1",
      "path": [],
      "text": "Med sommertid menes den perioden av året hvor klokkene stilles 60 minutter (en time) frem i forhold til resten av året.",
      "xml_path": "article#paragraf-1"
    },
    {
      "section_id": "paragraf-2",
      "provision_ref": "§ 2",
      "path": [],
      "text": "Sommertid fastsettes som normal tid for kongeriket Norge i tiden mellom kl. 0200 siste søndag i mars og kl. 0300 siste søndag i oktober.",
      "xml_path": "article#paragraf-2"
    },
    {
      "section_id": "paragraf-3",
      "provision_ref": "§ 3",
      "path": [],
      "text": "Forskriften trer i kraft 1. januar 2008.",
      "xml_path": "article#paragraf-3"
    }
  ]
}
