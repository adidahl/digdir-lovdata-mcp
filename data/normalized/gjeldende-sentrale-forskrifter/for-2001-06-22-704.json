  "sections": [
    {
      "section_id": "paragraf-1",
      "provision_ref": "§ 1",
      "heading": "Virkeområde",
      "path": [],
      "text": "Denne forskrift gjelder for de stillingskategorier hvor det i henhold til politiloven kan foretas åremålstilsetting.",
      "xml_path": "article#paragraf-1"
    },
    {
      "section_id": "paragraf-2",
      "provision_ref": "§ 2",
      "heading": "Varighet, fornyelse og opphør",
      "path": [],
      "text": "Åremålsperiodene skal være seks år og etter utlysning med mulighet for forlengelse én gang for hver person i samme stilling eller embete.",
      "xml_path": "article#paragraf-2"
    },
    {
      "section_id": "paragraf-3",
      "provision_ref": "§ 3",
      "heading": "Ikrafttredelse",
      "path": [],
      "text": "Denne forskrift trer i kraft straks.",
      "xml_path": "article#paragraf-3"
    }
  ]
}
