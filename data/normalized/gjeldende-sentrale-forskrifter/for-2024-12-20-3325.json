      "section_id": "paragraf-1",
      "provision_ref": "§ 1",
      "heading": "Standarder for bærekraftsrapportering for store foretak og morforetak i store konsern",
      "path": [],
      "text": "Regnskapspliktige som er store foretak eller morforetak i store konsern, og som etter regnskapsloven § 2-3 skal innta bærekraftsrapportering i årsberetningen, skal utarbeide bærekraftsrapporteringen etter regnskapsloven § 2-4 og § 2-5 i samsvar med vedlegg I og II til denne forskriften.",
      "xml_path": "article#paragraf-1"
    },
    {
      "section_id": "paragraf-2",
      "provision_ref": "§ 2",
      "heading": "Ikrafttredelse",
      "path": [],
      "text": "Forskriften trer i kraft straks.",
      "xml_path": "article#paragraf-2"
    }
  ]
