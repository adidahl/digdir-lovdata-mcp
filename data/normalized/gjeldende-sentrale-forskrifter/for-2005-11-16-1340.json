    {
      "section_id": "paragraf-1",
      "provision_ref": "§ 1",
      "path": [],
      "text": "Forskriften gjelder eksamen i emner definert som fjernundervisningsemner ved Høgskolen i Sør-Trøndelag.",
      "xml_path": "article#paragraf-1"
    },
    {
      "section_id": "paragraf-2",
      "provision_ref": "§ 2",
      "path": [],
      "text": "For perioden 1. januar 2006 – 31. desember 2006 fastsettes sensurfristen ved eksamener iflg. § 1 til fire uker – 20 virkedager.",
      "xml_path": "article#paragraf-2"
    },
    {
      "section_id": "paragraf-3",
      "provision_ref": "§ 3",
      "path": [],
      "text": "Denne forskriften trer i kraft fra 1. januar 2006.",
      "xml_path": "article#paragraf-3"
    }
  ]
